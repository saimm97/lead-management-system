DATABASE_URL=postgresql+asyncpg://leadpro:leadpro@localhost:5433/leadpro
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=reports@yourcompany.com
# CV Optimizer LLM (any OpenAI-compatible endpoint). Set the API key to enable.
# Examples:
#   Google Gemini (free tier): LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  LLM_MODEL=gemini-2.5-flash
#   OpenRouter:                LLM_BASE_URL=https://openrouter.ai/api/v1                              LLM_MODEL=z-ai/glm-5.2
#                              (leave LLM_MODEL empty to use your OpenRouter account default model)
#   Zhipu GLM:                 LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4                     LLM_MODEL=glm-4.5
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL=gemini-2.5-flash
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS — comma-separated allowed origins (add your deployed frontend URL)
CORS_ORIGINS=http://localhost:3000
# Optional regex to allow dynamic origins (e.g. Vercel preview deployments):
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
FRONTEND_URL=http://localhost:3000
ADMIN_EMAIL=admin@leadpro.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=System Admin

# Google Calendar integration (leave blank to disable)
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console,
# enable the Google Calendar API, and register the redirect URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/calendar/callback
